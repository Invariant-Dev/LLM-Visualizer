# LLM Internals Explorer Configuration

# Ollama server URL (default: http://localhost:11434)
VITE_OLLAMA_BASE_URL=http://localhost:11434

# Model to use (default: llama2)
VITE_DEFAULT_MODEL=llama2

# Server port
SERVER_PORT=3001

# Enable mock mode (set to "true" to always use mock data)
VITE_FORCE_MOCK=false
